# Story generation:
# Use "mock" or "openai".
STORY_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Image generation:
# Use "mock", "openai", or "grok".
IMAGE_PROVIDER=mock
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_FORMAT=jpeg
OPENAI_IMAGE_COMPRESSION=80
OPENAI_IMAGE_REFERENCE_FALLBACK=true
XAI_API_KEY=
XAI_IMAGE_MODEL=grok-imagine-image-quality
XAI_IMAGE_ASPECT_RATIO=16:9
XAI_IMAGE_RESOLUTION=1k
XAI_IMAGE_REFERENCE_FALLBACK=true

# Optional for manual tunnel setups. run-online.ps1 generates this automatically.
ACCESS_PASSWORD=
